{
  "name": "aimashi",
  "version": "0.1.0",
  "private": true,
  "productName": "Aimashi",
  "description": "Aimashi desktop demo with an app-owned Hermes runtime home.",
  "main": "src/main.js",
  "scripts": {
    "test": "node --test 'tests/*.test.js'",
    "open": "electron .",
    "start": "electron .",
    "relay": "node src/relay/server.js",
    "check": "node src/check.js",
    "hermes:runtime": "bash scripts/build-hermes-runtime.sh",
    "hermes:runtime:mac-arm64": "bash scripts/build-hermes-runtime.sh mac-arm64",
    "hermes:runtime:mac-x64": "bash scripts/build-hermes-runtime.sh mac-x64",
    "hermes:runtime:linux-x64": "bash scripts/build-hermes-runtime.sh linux-x64",
    "hermes:runtime:win-x64": "bash scripts/build-hermes-runtime.sh win-x64",
    "prepack": "npm run hermes:runtime",
    "pack": "electron-builder --dir",
    "dist": "npm run dist:mac",
    "dist:mac": "npm run hermes:runtime:mac-arm64 && electron-builder --mac dir && node scripts/create-mac-dmg.js"
  },
  "hermes": {
    "version": "2026.5.7",
    "pythonVersion": "3.11.13",
    "pbsRelease": "20251007"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.139",
    "@openai/codex-sdk": "^0.130.0",
    "cron-parser": "^4.9.0",
    "js-yaml": "^4.1.1",
    "qrcode": "^1.5.4",
    "ws": "^8.20.1"
  },
  "build": {
    "appId": "ai.aimashi.app",
    "productName": "Aimashi",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "package.json",
      "src/**/*",
      "resources/official-library/**/*",
      "resources/conductor/**/*",
      "!src/**/*.map",
      "!node_modules/@anthropic-ai/claude-agent-sdk-*-*/**",
      "!node_modules/@openai/codex-*-*/**"
    ],
    "extraResources": [
      {
        "from": "resources/pet-generator",
        "to": "pet-generator",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "skills",
        "to": "skills",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.productivity",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "vendor/hermes-runtime/mac-arm64",
          "to": "hermes-runtime",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "dmg": {
      "sign": false,
      "format": "ULFO"
    }
  }
}
